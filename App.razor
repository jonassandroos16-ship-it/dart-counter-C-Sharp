@if (_loading)
{
    <div class="app-shell" style="display:flex;align-items:center;justify-content:center;">
        <div style="text-align:center;color:var(--muted);">
            <div style="font-size:48px;margin-bottom:12px;">🎯</div>
            <div>Loading Dart Wars...</div>
        </div>
    </div>
    return;
}

<div class="app-shell">
    @if (!_welcomeDone)
    {
        <div class="welcome-overlay">
            <div class="welcome-stage">
                <div class="welcome-rings">
                    <span class="ring r1"></span>
                    <span class="ring r2"></span>
                    <span class="ring r3"></span>
                </div>
                <h1 class="welcome-title">
                    <span class="word w1">Dart</span>
                    <span class="word w2">Wars</span>
                </h1>
                <p class="welcome-sub">Aim. Score. Conquer.</p>
                <button class="welcome-cta" @onclick="DismissWelcome">
                    <span class="welcome-cta-inner">Press to continue</span>
                </button>
            </div>
        </div>
    }

    @if (_view == "play")
    {
        <PlayView />
    }
    else if (_view == "players")
    {
        <div class="view-scroll">
            <PlayersView />
        </div>
    }
    else if (_view == "stats")
    {
        <StatsView />
    }
    else if (_view == "history")
    {
        <HistoryView />
    }
    else if (_view == "settings")
    {
        <SettingsView />
    }

    <button class="nav-toggle @(_navOpen ? "open" : "")" @onclick="ToggleNav" aria-label="@(_navOpen ? "Hide navigation" : "Show navigation")">
        @if (_navOpen)
        {
            <text>▲</text>
        }
        else
        {
            <text>▼</text>
        }
    </button>

    <nav class="nav @(_navOpen ? "open" : "")">
        @foreach (var item in _nav)
        {
            <button class="@(_view == item.Id ? "active" : "")" @onclick="() => SetView(item.Id)">
                <span class="nav-icon">@item.Icon</span>
                <span>@item.Label</span>
            </button>
        }
    </nav>

    @if (Toast.Visible)
    {
        <div class="toast show">@Toast.Message</div>
    }
</div>
