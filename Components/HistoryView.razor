@using dart_counter.Logic

<div class="view-scroll">
    <h2 style="margin-bottom:16px;">Match History</h2>

    @if (State.Games.Count == 0)
    {
        <div class="empty">No games played yet.</div>
    }
    else
    {
        @foreach (var game in State.Games.OrderByDescending(g => g.Date))
        {
            <div class="card" style="cursor:pointer;" @onclick="() => ShowDetail(game)">
                <div class="row between">
                    <div class="row" style="gap:8px;align-items:center;">
                        <span style="font-size:24px;">
                            @(game.Atc ? "🕐" : game.Mode == "killer" ? "💀" : game.Mode == "battle" ? "⚔️" : game.Mode == "highscore" ? "🎰" : game.Mode == "speed101" ? "⚡" : game.Practice ? "🎯" : "🏆")
                        </span>
                        <div>
                            <div style="font-weight:600;">@(GameModes.Modes.ContainsKey(game.Mode) ? GameModes.Modes[game.Mode].Label : game.Mode)</div>
                            <div class="muted small">@GameLogic.FmtDateTime(game.Date)</div>
                        </div>
                    </div>
                    <div class="row" style="gap:6px;">
                        @if (game.Winner != null)
                        {
                            var w = game.Players.FirstOrDefault(p => p.Id == game.Winner);
                            <span class="pill" style="background:color-mix(in srgb,var(--accent) 15%,var(--bg-3));color:var(--accent);">🏆 @(w?.Name ?? "?")</span>
                        }
                        else if (game.Tied)
                        {
                            <span class="pill">🤝 Tie</span>
                        }
                        else
                        {
                            <span class="pill muted">Practice</span>
                        }
                    </div>
                </div>
                <div class="row wrap" style="gap:6px;margin-top:8px;">
                    @foreach (var p in game.Players)
                    {
                        <span class="avatar sm" style="background:@p.Color;" title="@p.Name">@GameLogic.Initials(p.Name)</span>
                    }
                </div>
            </div>
        }
    }
</div>

@if (_detailGame != null)
{
    <div class="modal-bg" @onclick="CloseDetail">
        <div class="modal" @onclick:stopPropagation>
            <h2 style="margin-bottom:4px;">@(GameModes.Modes.ContainsKey(_detailGame.Mode) ? GameModes.Modes[_detailGame.Mode].Label : _detailGame.Mode)</h2>
            <div class="muted small" style="margin-bottom:16px;">@GameLogic.FmtDateTime(_detailGame.Date)</div>

            @if (_detailGame.Winner != null)
            {
                var w = _detailGame.Players.FirstOrDefault(p => p.Id == _detailGame.Winner);
                <div class="pill" style="background:color-mix(in srgb,var(--accent) 15%,var(--bg-3));color:var(--accent);margin-bottom:12px;">🏆 Winner: @(w?.Name ?? "?")</div>
            }

            @foreach (var p in _detailGame.Players)
            {
                <div class="card" style="margin-bottom:8px;">
                    <div class="row between" style="margin-bottom:8px;">
                        <div class="row" style="gap:8px;align-items:center;">
                            <span class="avatar sm" style="background:@p.Color;">@GameLogic.Initials(p.Name)</span>
                            <span style="font-weight:600;">@p.Name</span>
                        </div>
                        <div class="muted small">
                            @if (_detailGame.Atc) { <text>@p.DartsThrown darts</text> }
                            else if (_detailGame.Mode == "battle") { <text>@(p.DamageDealt ?? 0) dmg</text> }
                            else if (_detailGame.Mode == "killer") { <text>❤️@(p.Lives ?? 0)</text> }
                            else { <text>@GameLogic.VisitAvgStatic(p).ToString("F1") avg · @p.LegsWon legs</text> }
                        </div>
                    </div>
                    @if (p.Visits.Count > 0)
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:4px;">
                            @foreach (var v in p.Visits)
                            {
                                <div style="background:var(--bg-3);border:1px solid var(--border);border-radius:6px;padding:4px 8px;font-size:12px;@(v.Bust ? "opacity:.5;" : "")">
                                    <span style="font-weight:700;">@(v.Scored)@(v.Bust ? " BUST" : "")</span>
                                    <span class="muted" style="margin-left:4px;">@string.Join(" ", (v.Darts ?? new()).Select(d => d.Label))</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <div class="row" style="gap:8px;margin-top:12px;">
                <button class="btn danger block" @onclick="() => DeleteGame(_detailGame)">Delete</button>
                <button class="btn block" @onclick="CloseDetail">Close</button>
            </div>
        </div>
    </div>
}