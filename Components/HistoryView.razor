@if (State.Games.Count == 0)
{
    <div class="view-scroll"><h2 style="margin-bottom:12px;">Match History</h2><div class="card empty">No games played yet.</div></div>
    return;
}

<div class="view-scroll">
    <h2 style="margin-bottom:12px;">Match History</h2>

    @if (State.Games.Count > 0)
    {
        <div class="card" style="margin-bottom:12px;">
            <div class="muted small" style="margin-bottom:8px;">Win Rate Summary</div>
            @{
                var playerIds = State.Games.SelectMany(g => g.Players.Select(p => p.Id)).Distinct().ToList();
            }
            @foreach (var pid in playerIds)
            {
                var pName = State.Games.SelectMany(g => g.Players.Where(p => p.Id == pid)).FirstOrDefault()?.Name ?? "Unknown";
                var stats = GameLogic.PlayerStats_(pid, State.Games);
                <div class="row between" style="margin-bottom:6px;">
                    <div class="row" style="gap:8px;align-items:center;">
                        <span style="font-weight:600;">@pName</span>
                        <span class="muted small">@stats.GamesWon/@stats.CompetitiveGames games · @stats.Games total</span>
                    </div>
                    <div class="row" style="gap:8px;align-items:center;">
                        <div style="width:100px;height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
                            <div style="width:@(stats.WinRate.ToString("F0"))%;height:100%;background:var(--accent);border-radius:3px;transition:width .4s ease;"></div>
                        </div>
                        <span style="font-weight:700;font-size:14px;min-width:40px;text-align:right;">@stats.WinRate.ToString("F0")%</span>
                    </div>
                </div>
            }
        </div>
    }

    @foreach (var g in Enumerable.Reverse(State.Games))
    {
        var w = g.Players.FirstOrDefault(p => p.Id == g.Winner);
        var isSolo = g.Players.Count < 2;
        var gameLabel = g.Atc ? (isSolo ? "Solo Around the Clock" : w != null ? "Winner: " + w.Name : "Around the Clock")
            : g.Practice ? "Practice session"
            : isSolo ? "Solo session"
            : (w != null ? "Winner: " + w.Name : "");
        <div class="card" style="padding:12px;cursor:pointer;margin-bottom:8px;" @onclick="() => _detail = g">
            <div class="row between">
                <div>
                    <div class="row" style="gap:8px;">
                        <span class="pill">@(GameModes.Modes.ContainsKey(g.Mode) ? GameModes.Modes[g.Mode].Label : g.Mode)</span>
                        <span class="muted small">@GameLogic.FmtDate(g.Date) @GameLogic.FmtTime(g.Date)</span>
                    </div>
                    <div style="margin-top:8px;font-weight:700;">@string.Join("  vs  ", g.Players.Select(p => p.Name))</div>
                    <div class="muted small" style="margin-top:2px;">@gameLabel</div>
                </div>
                <div style="text-align:right;">
                    @foreach (var p in g.Players)
                    {
                        <div class="small">
                            @if (g.Atc)
                            {
                                <b>@p.DartsThrown</b> <span class="muted">darts</span>
                            }
                            else
                            {
                                <b>@GameLogic.VisitAvgStatic(p).ToString("F1")</b> <span class="muted">avg</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (_detail != null)
{
    <div class="modal-bg" @onclick="() => _detail = null">
        <div class="modal" @onclick:stopPropagation>
            <div style="max-height:70vh;overflow:auto;">
                <h3 style="margin-bottom:4px;">@(GameModes.Modes.ContainsKey(_detail.Mode) ? GameModes.Modes[_detail.Mode].Label : _detail.Mode)</h3>
                <div class="muted small" style="margin-bottom:12px;">@GameLogic.FmtDateTime(_detail.Date)</div>
                @foreach (var p in _detail.Players)
                {
                    var best = p.Visits.Count > 0 ? p.Visits.Where(v => !v.Bust).Select(v => v.Scored).DefaultIfEmpty(0).Max() : 0;
                    <div class="list-item" style="flex-direction:column;align-items:stretch;gap:6px;">
                        <div class="row between">
                            <b>
                                <span class="avatar" style="width:22px;height:22px;font-size:10px;background:@p.Color;">@GameLogic.Initials(p.Name)</span>
                                @p.Name
                            </b>
                            <span class="muted small">@GameLogic.VisitAvgStatic(p).ToString("F1") avg · best @best · @p.LegsWon legs</span>
                        </div>
                        <div class="muted small" style="line-height:1.7;">
                            @foreach (var v in p.Visits)
                            {
                                var darts = string.Join(", ", v.Darts.Select(d => d.Label));
                                <span class="pill" style="margin:2px 2px 0 0;background:@(v.Bust ? "var(--danger-bg)" : v.Remaining == 0 ? "var(--accent-bg)" : "var(--bg)");">
                                    @(v.Bust ? "BUST" : v.Scored.ToString()) <span style="color:var(--muted);margin-left:4px;">(@darts)</span>
                                </span>
                            }
                        </div>
                    </div>
                }
                <div class="row" style="gap:8px;margin-top:12px;">
                    <button class="btn block danger" @onclick="() => DeleteGame(_detail)">Delete</button>
                    <button class="btn block primary" @onclick="() => _detail = null">Close</button>
                </div>
            </div>
        </div>
    </div>
}
